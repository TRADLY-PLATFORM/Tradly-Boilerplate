# ─── Tradly Workspace ─────────────────────────────────────────────────────────
# Your Tradly workspace domain (e.g. beauty.tradly.co)
NEXT_PUBLIC_TRADLY_DOMAIN=your-workspace.tradly.co

# Public key for your workspace — get this from your Tradly dashboard
NEXT_PUBLIC_TRADLY_PK_KEY=your-public-key

# Deployment environment: production | development | sandbox
NEXT_PUBLIC_TRADLY_ENV=production

# ─── Defaults ─────────────────────────────────────────────────────────────────
# Hardcoded fallback currency and language.
# These can be swapped at runtime via state/app/slice (setCurrency / setLanguage).
NEXT_PUBLIC_DEFAULT_CURRENCY=USD
NEXT_PUBLIC_DEFAULT_LANGUAGE=en

## Delete Cart Item

```tsx
import { useDeleteCartItemMutation } from '@/state/cart/api'

const [deleteCartItem, { isLoading }] = useDeleteCartItemMutation()

const handleDelete = async (item: CartItem) => {
  // Pass listing_id from cart_details[].listing.id — NOT the cart detail's own id.
  // The API receives: { cart: { listing_id: [507598] } }
  const result = await deleteCartItem({ listing_id: item.listing.id })

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }
  // cartApi invalidated → cart re-fetches without the item
  // listingApi invalidated → listing.in_cart becomes false
}
```


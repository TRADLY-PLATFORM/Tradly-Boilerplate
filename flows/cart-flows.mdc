## events / appointments — Book Now

One booking at a time — cart must be cleared before adding.
Auth required — guests must sign in first.

```tsx
import { useAuthSelector } from '@/state/auth/selectors'

const isAuthenticated = useAuthSelector(s => s.isAuthenticated)
const [addToCart] = useAddToCartMutation()
const [clearCart] = useClearCartMutation()

const handleBookNow = async () => {
  // Auth gate — events/appointments always require sign-in
  if (!isAuthenticated) {
    router.push('/sign-in')
    return
  }

  const err = validateBeforeAdd(listing, selectedVariantId)
  if (err) { showToast(err); return }

  // For events: show schedule picker if listing.schedules.length > 0
  // selectedVariantId here may be a schedule/slot id

  // Clear first — only one event/appointment allowed in cart at a time
  const clearResult = await clearCart()
  if ('error' in clearResult) { showToast('Failed to clear cart'); return }

  const result = await addToCart({
    listing_id: listing.id,
    quantity: 1,  // events/appointments are always qty 1
    // Only include variant_id when a slot/ticket type is actually selected
    ...((listing.variants as unknown[]).length > 0 && selectedVariantId
      ? { variant_id: selectedVariantId }
      : {}),
  })

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  router.push('/checkout')
}
```


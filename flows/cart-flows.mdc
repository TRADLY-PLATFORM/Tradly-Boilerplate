## Get Cart

Fetch once at app root or cart page. All child components read from cache via selectors.

```tsx
import { useGetCartQuery } from '@/state/cart/api'

const { data, isLoading } = useGetCartQuery()

const items      = data?.cart_details ?? []
const summary    = data?.cart
const grandTotal = summary?.grand_total.formatted   // "$ 109.89"
const itemCount  = items.reduce((sum, item) => sum + item.quantity, 0)

// Pricing breakdown — only render rows where display: true
const priceRows = summary?.pricing_items.filter(p => p.display) ?? []

// Per item
items.forEach(item => {
  item.listing.title
  item.listing.images[0]
  item.listing.offer_price.formatted        // unit price
  item.quantity_total_offer_price.formatted // line total
  item.listing.account.name
  item.variant?.name                        // e.g. "Red / L"
})
```

### Cart count in header (no extra fetch)

```tsx
import { useCartItemCount } from '@/state/cart/selectors'

const count = useCartItemCount()  // reads from cache — zero network cost
{count > 0 && <span className="badge">{count}</span>}
```


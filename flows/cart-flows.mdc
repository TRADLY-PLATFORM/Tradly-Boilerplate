import { useCartItems, useCartSummary, useCartItemCount } from '@/state/cart/selectors'

const items   = useCartItems()      // CartItem[] — from cache, no fetch
const summary = useCartSummary()    // CartSummary | null
const count   = useCartItemCount()  // total quantity across all items

## donation — Fund Now

User enters a custom amount. Cart cleared first — only one donation per checkout.

```tsx
const [donationAmount, setDonationAmount] = useState<number>(0)
const [addToCart] = useAddToCartMutation()
const [clearCart] = useClearCartMutation()

const handleFundNow = async () => {
  if (donationAmount <= 0) { showToast('Enter a valid amount'); return }

  // Goal progress display
  // listing.goal_price.amount → total goal
  // donationAmount → user's contribution

  // Clear first — only one donation per checkout
  const clearResult = await clearCart()
  if ('error' in clearResult) { showToast('Failed to prepare checkout'); return }

  const result = await addToCart({
    listing_id: listing.id,
    quantity: 1,
    custom_price: donationAmount,   // ← required for donations
  })

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  router.push('/checkout')
}

// Goal progress bar
const goalAmount = listing.goal_price.amount
const progressPercent = goalAmount > 0
  ? Math.min((raisedAmount / goalAmount) * 100, 100)
  : 0
```


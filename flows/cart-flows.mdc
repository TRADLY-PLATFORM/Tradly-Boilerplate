## Shared Validation

Run before any addToCart call regardless of order_type.

```tsx
import type { Listing } from '@/types/listing.types'

const validateBeforeAdd = (listing: Listing, selectedVariantId: number | null): string | null => {
  if (listing.stock === 0) return 'Out of stock'
  if (listing.sold) return 'This item has been sold'
  if ((listing.variants as unknown[]).length > 0 && !selectedVariantId) return 'Please select a variant'
  return null
}
```


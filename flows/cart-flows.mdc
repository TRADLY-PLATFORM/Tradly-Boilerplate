## Clear Entire Cart

```tsx
import { useClearCartMutation } from '@/state/cart/api'

const [clearCart, { isLoading }] = useClearCartMutation()

const handleClearCart = async () => {
  const result = await clearCart()
  if ('error' in result) { showToast('Failed to clear cart'); return }
  // Cart cache invalidated → re-fetches empty
  // Listing cache invalidated → all in_cart → false
}
```


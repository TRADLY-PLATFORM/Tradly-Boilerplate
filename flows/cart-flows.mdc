## What NOT to do

```ts
// Never check order_type with a hardcoded number — it's a string
if (listing.type === 2) // ❌
if (listing.order_type === 'events') // ✓

// Never skip the clearCart step for events/appointments/donations
await addToCart({ listing_id: id, quantity: 1 })  // ❌ for events
await clearCart(); await addToCart(...)            // ✓

// Never call addToCart for information_listing or video_listing — they have no cart flow

// Never pass custom_price for listings/events — only for donation
addToCart({ listing_id: id, quantity: 1, custom_price: 50 })  // ❌ for listings

// Never pass uuid — injected automatically for guests
addToCart({ listing_id: 1, quantity: 1, uuid: deviceId })  // ❌

// Never manually update in_cart or cart count — cache invalidation handles it
setIsInCart(true)  // ❌
```

## listings / digital — Add to Cart

Physical products and digital goods. Multi-item cart allowed.
Guest checkout supported — no auth required.

```tsx
import { useAddToCartMutation, useClearCartMutation } from '@/state/cart/api'
import type { AddToCartInput } from '@/types/cart.types'

const [addToCart, { isLoading }] = useAddToCartMutation()
const [clearCart] = useClearCartMutation()
const [showClearModal, setShowClearModal] = useState(false)
const [pendingInput, setPendingInput] = useState<AddToCartInput | null>(null)

const handleAddToCart = async () => {
  const err = validateBeforeAdd(listing, selectedVariantId)
  if (err) { showToast(err); return }

  const input: AddToCartInput = {
    listing_id: listing.id,
    quantity: selectedQuantity,
    // Only include variant_id when the listing actually has variants AND one is selected.
    // Never pass variant_id: 0 or variant_id: undefined — omit the key entirely.
    ...((listing.variants as unknown[]).length > 0 && selectedVariantId
      ? { variant_id: selectedVariantId }
      : {}),
  }

  const result = await addToCart(input)

  if ('error' in result) {
    const e = result.error as { status: string; error: string; data?: { code: number } }

    if (e.data?.code === 480) {
      // Cart has items from a different seller — prompt user to clear
      setPendingInput(input)
      setShowClearModal(true)
      return
    }
    if (e.data?.code === 489) {
      // Cart conflict — clear silently and retry once
      await clearCart()
      await addToCart(input)
      return
    }

    showToast(e.error)
    return
  }

  // cartApi cache invalidated → cart re-fetches with new item
  // listingApi cache invalidated → listing.in_cart becomes true
  showToast('Added to cart')
}

// Buy Now — same as Add to Cart but navigates to checkout immediately
const handleBuyNow = async () => {
  const err = validateBeforeAdd(listing, selectedVariantId)
  if (err) { showToast(err); return }

  const result = await addToCart({
    listing_id: listing.id,
    quantity: selectedQuantity,
    ...((listing.variants as unknown[]).length > 0 && selectedVariantId
      ? { variant_id: selectedVariantId }
      : {}),
  })

  if ('error' in result) { /* same 480/489 handling */ return }
  router.push('/checkout')
}
```

### Multi-Seller Modal (error 480)

```tsx
const handleConfirmClear = async () => {
  setShowClearModal(false)
  if (!pendingInput) return
  await clearCart()
  await addToCart(pendingInput)
  setPendingInput(null)
}

{showClearModal && (
  <Modal>
    <p>Your cart has items from another seller. Clear cart and add this item?</p>
    <button onClick={() => setShowClearModal(false)}>Cancel</button>
    <button onClick={handleConfirmClear}>Clear & Add</button>
  </Modal>
)}
```


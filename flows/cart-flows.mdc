## Types Reference

```ts
// @/types/cart.types.ts

interface AddToCartInput {
  listing_id: number
  quantity: number
  variant_id?: number    // required when listing.variants.length > 0
  custom_price?: number  // donations only — from user's input field
}

interface DeleteCartItemInput {
  listing_id: number  // cart_details[].listing.id — sent as array by the SDK wrapper
}

interface CartItem {
  id: number
  quantity: number
  custom_price: string              // "0.0000" — string from API
  quantity_total_price: Money       // list_price × quantity
  quantity_total_offer_price: Money // offer_price × quantity ← use for display
  listing: CartListing
  variant?: CartVariant | null
}

interface CartListing {
  id: number; title: string; slug: string; images: string[]
  list_price: Money; offer_price: Money
  stock: number; max_quantity: number; in_cart: boolean
  account: { id: number; name: string; slug: string; images: string[] }
}

interface CartSummary {
  id: number
  total: Money; list_total: Money; offer_total: Money
  shipping_total: Money
  grand_total: Money    // ← use this as the final checkout total
  pricing_items: PricingItem[]
}

interface PricingItem {
  name: string; type: string; short_code: string
  display: boolean  // ← only render rows where display: true
  buying: Money; note?: string
}
```


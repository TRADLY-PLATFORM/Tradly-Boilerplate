## Cart Commissions

```tsx
import { useGetCartCommissionsQuery, useGetDemandCommissionsQuery } from '@/state/commissions/api'
import type { CartCommissionEntry } from '@/types/checkout.types'

// Cart commissions — buyer enters amounts, required ones block checkout
const { data: cartCommData } = useGetCartCommissionsQuery()
const cartCommissions = cartCommData?.commissions ?? []

// Demand commissions — optional toggles, authenticated only
const { data: demandCommData } = useGetDemandCommissionsQuery(undefined, { skip: !isAuthenticated })
const demandCommissions = demandCommData?.commissions ?? []

// State
const [cartCommEntries, setCartCommEntries] = useState<CartCommissionEntry[]>([])
const [demandCommIds,   setDemandCommIds]   = useState<number[]>([])

// Apply a cart commission entry (amount must be within min/max bounds)
const applyCartComm = (entry: CartCommissionEntry) =>
  setCartCommEntries(prev => [...prev.filter(e => e.id !== entry.id), entry])

// Toggle demand commission
const toggleDemandComm = (id: number) =>
  setDemandCommIds(prev => prev.includes(id) ? prev.filter(x => x !== id) : [...prev, id])

// Validation — non-optional commissions must be applied before checkout
const missingComm = cartCommissions.find(
  c => !c.commission_data.optional && !cartCommEntries.find(e => e.id === c.id)
)
if (missingComm) return `Apply required commission: ${missingComm.title}`

// In payload:
// cart_commission:   cartCommEntries     → [{ id, amount }]
// demand_commission: demandCommIds       → [id, id, ...]
```


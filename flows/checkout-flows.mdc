## Direct Checkout (Buy Now)

Bypasses cart entirely — purchase directly from listing detail page.

```tsx
import { useDirectCheckoutMutation } from '@/state/orders/api'

const [directCheckout] = useDirectCheckoutMutation()

const result = await directCheckout({
  listingId: listing.id,
  input: {
    listing: {
      id: listing.id,
      quantity: 1,
      ...(variantId ? { variant_id: variantId } : {}),
      ...(listing.order_type === 'donation' ? { custom_price: donationAmount } : {}),
    },
    ...(selectedShippingId ? { shipping_method: { id: selectedShippingId } } : {}),
    ...(selectedAddressId  ? { address: { id: selectedAddressId } } : {}),
    ...(selectedPaymentId  ? { payment_method: { id: selectedPaymentId } } : {}),
  },
})

if (!('error' in result)) {
  navigate(`/thank-you/${result.data.order_reference}`)
}
```


## What NOT to do

```ts
// ❌ Never construct { order: {...} } in components — api/checkout.ts does the nesting
const payload = { order: { payment_method_id: pm.id } }
// ✓ Use flat FullCheckoutPayload — transformation is automatic

// ❌ Never pass uuid from components — api/checkout.ts injects it for guests
checkout({ cart: { uuid: deviceId } })
// ✓ Omit cart.uuid — injected automatically when authKey is empty

// ❌ Never skip { skip: !isAuthenticated } on address fetch
useGetAddressesQuery()
// ✓ Always: useGetAddressesQuery(undefined, { skip: !isAuthenticated })

// ❌ Never hardcode order_reference in navigate
navigate('/thank-you/123')
// ✓ navigate(`/thank-you/${result.data.order_reference}`)

// ❌ Never check selectedPayment.channel === 'stripe' — channel is 'sdk', type is 'stripe'
if (pm.channel === 'stripe') { ... }
// ✓ if (pm.type === 'stripe') { ... }

// ❌ Never show shipping / address sections for events, appointments, donation, digital
if (checkoutType === 'events') { /* still show shipping */ }
// ✓ const needsShipping = !SPECIAL_TYPES.includes(checkoutType) && checkoutType !== 'digital'

// ❌ Never pass coupon_code manually from user input — use cart.coupon.code (post-API apply)
checkout({ coupon_code: userTypedCode })
// ✓ Coupon is applied via useApplyCouponMutation first; payload reads summary.coupon.code
```

## Coupon

```tsx
import { useApplyCouponMutation, useRemoveCouponMutation } from '@/state/cart/api'

const [applyCoupon,  { isLoading: applying  }] = useApplyCouponMutation()
const [removeCoupon, { isLoading: removing  }] = useRemoveCouponMutation()

// Apply
const result = await applyCoupon({ cartId: summary.id, code: couponCode })
// On success: cart re-fetches (tag invalidation) → summary.coupon.code is populated

// Remove
await removeCoupon({ cartId: summary.id })

// In payload — use cart.coupon.code as source of truth (applied via API, not passed manually):
const couponPayload = summary?.coupon?.code ? { coupon_code: summary.coupon.code } : {}
```


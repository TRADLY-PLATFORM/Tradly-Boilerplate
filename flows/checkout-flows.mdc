## FullCheckoutPayload (flat type used in components)

```ts
// @/types/checkout.types.ts → FullCheckoutPayload

const payload: FullCheckoutPayload = {
  // Cart reference
  cart: { id: summary.id },              // omit for guest; uuid auto-injected

  // Order type — comes from listing.order_type
  type: 'listings',                      // 'listings' | 'events' | 'appointments' | 'donation' | 'digital'

  // Shipping — omit entirely for 'digital' and special types
  shipping_method_id: selectedShipping.id,

  // Address
  shipping_address_id: selectedAddress.id,         // authenticated delivery
  // OR:
  shipping_address: { name: 'Jane', email: 'j@co' }, // guest delivery
  // OR:
  shipping_address_id: selectedHub.id,             // storage_hub type

  // Sub-shipment (SendCloud or external extension)
  external_shipping_method_id: selectedShipment.id,

  // Payment
  payment_method_id: selectedPayment.id,

  // Coupon — use cart.coupon.code (source of truth); applied via API, not passed manually
  coupon_code: summary.coupon.code,

  // Cart commissions — buyer-entered amounts
  cart_commission: [{ id: 1, amount: 50 }, { id: 2, amount: 20 }],

  // Demand commissions — ids of enabled optional commissions
  demand_commission: [3, 5],

  // Events / appointments — "YYYY-MM-DD HH:MM:00"
  schedule_start_at: '2025-03-01 10:00:00',
  schedule_end_at:   '2025-03-01 11:00:00',

  // Donation
  anonymous_donation: true,

  // Guest (when !isAuthenticated)
  guest: true,
  guest_email: 'buyer@email.com',
  guest_name:  'Jane Doe',
  guest_phone: '+1 555 000 0000',
}
```


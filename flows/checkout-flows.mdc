## Payment Channel Routing

After `useCheckoutMutation` succeeds, route based on `selectedPayment.channel` / `selectedPayment.type`:

```ts
import { buildWebPaymentUrl } from '@/api/checkout'
import { usePaymentIntentMutation } from '@/state/orders/api'

const [paymentIntent] = usePaymentIntentMutation()

const routePayment = async (orderRef: string, pm: PaymentMethod) => {
  // Stripe SDK — create payment intent → /payment page
  if (pm.type === 'stripe') {
    const result = await paymentIntent(orderRef)
    if (!('error' in result)) {
      navigate('/payment', {
        state: { client_secret: result.data.client_secret, order_reference: orderRef }
      })
    }
    return
  }

  // Web gateways — open paymentIntent URL in new window
  // Covers: stripe_web, razorpay, billplz, payulatam, paydunya, mangopay, opp
  const webTypes = ['stripe_web','razorpay','billplz','payulatam','paydunya','mangopay','opp']
  if (pm.channel === 'web' || webTypes.includes(pm.type)) {
    const url = buildWebPaymentUrl(orderRef, pm.id, authKey, guestEmail)
    window.open(url)
    navigate(`/thank-you/${orderRef}`)
    return
  }

  // Native gateways (pawapay, korapay, paystack, flutterwave, checkoutcom, commercepay)
  // → call respective deposit endpoint → open res.redirect_url
  // These are payment-gateway-specific; see api/checkout.ts for buildWebPaymentUrl pattern

  // Wallet, cash_on_delivery, default
  navigate(`/thank-you/${orderRef}`)
}
```

**Web payment URL format:**
```
https://{domain}/v1/payments/web/paymentIntent
  ?order_reference={ref}
  &payment_method_id={id}
  &agent=web
  &auth_key={key}         // authenticated users
  &guest_email={email}    // guest users
```
Built by `buildWebPaymentUrl(ref, pmId, authKey, guestEmail?)` in `api/checkout.ts`.


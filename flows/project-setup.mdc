## What NOT to do

```ts
// Never call api/*.ts directly from a component
import { getListings } from '@/api/listing'

// Never set auth state manually from a component
dispatch(setCredentials(user))

// Never manually update liked / in_cart / cart count
setIsInCart(true)
setLiked(false)

// Never pass authKey, currency, or language from a component to a hook
// — they are read from Redux state inside every queryFn automatically

// Never add RTK Query caches to redux-persist whitelist
// state/store.ts whitelist: ['auth', 'app']  ← only these two, never 'cartApi' or 'listingApi'

// Never use uuid from a component — injected automatically for guest users in api/cart.ts
addToCart({ listing_id: 1, quantity: 1, uuid: deviceId }, ...)
```

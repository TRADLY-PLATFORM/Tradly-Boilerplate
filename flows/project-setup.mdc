## Reading State — Quick Reference

```tsx
// Auth
import { useAuthSelector } from '@/state/auth/selectors'
const isAuthenticated = useAuthSelector(s => s.isAuthenticated)
const authKey         = useAuthSelector(s => s.authKey)
const firstName       = useAuthSelector(s => s.firstName)

// Listings — triggers fetch
import { useGetListingsQuery, useGetListingDetailQuery } from '@/state/listing/api'
const { data, isLoading } = useGetListingsQuery({ page: 1 })
const { data }            = useGetListingDetailQuery({ slug: 'my-product' })

// Listings — cache only (deep components, no extra fetch)
import { useListingsResult, useListingDetailResult } from '@/state/listing/selectors'
const { data } = useListingDetailResult({ slug: 'my-product' })

// Cart — triggers fetch
import { useGetCartQuery } from '@/state/cart/api'
const { data } = useGetCartQuery()

// Cart — cache only (deep components, no extra fetch)
import { useCartItems, useCartSummary, useCartItemCount } from '@/state/cart/selectors'
const items   = useCartItems()     // CartItem[]
const summary = useCartSummary()   // CartSummary | null
const count   = useCartItemCount() // total quantity for badge
```


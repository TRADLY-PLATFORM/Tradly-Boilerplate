## Token Refresh

Skips the API call if `tokenSetAt` < 1 hour ago. Dispatches `logout()` on failure (which also resets cart + listing caches).

### On app load (every page reload)

```tsx
import { useEffect, useState } from 'react'
import { useRefreshAuthMutation } from '@/state/auth/api'
import { useAuthSelector } from '@/state/auth/selectors'

const [refreshAuth] = useRefreshAuthMutation()
const isAuthenticated = useAuthSelector(s => s.isAuthenticated)
const [ready, setReady] = useState(false)

useEffect(() => {
  const init = async () => {
    if (isAuthenticated) {
      await refreshAuth()
      // Success → state.auth.authKey + refreshKey + tokenSetAt updated
      // Failure → logout() dispatched → auth state cleared + cart/listing cache reset
    }
    setReady(true)
  }
  init()
}, [])

if (!ready) return <SplashScreen />
return <App />
```

### In protected route guard

```tsx
const [checked, setChecked] = useState(false)
const [refreshAuth] = useRefreshAuthMutation()
const isAuthenticated = useAuthSelector(s => s.isAuthenticated)

useEffect(() => {
  const guard = async () => {
    if (!isAuthenticated) { router.push('/sign-in'); return }
    const result = await refreshAuth()
    if ('error' in result) { router.push('/sign-in'); return }
    setChecked(true)
  }
  guard()
}, [])

if (!checked) return <LoadingSpinner />
return <>{children}</>
```


## Sign Up → Verify OTP — Full Flow

This is a two-screen flow. The `verifyId` connects them.

```
sign-up screen → signUp() → verifyId stored in Redux → navigate to verify-otp screen
verify-otp screen → reads verifyId from Redux → verifyOtp() → user authenticated
```

### Screen 1 — Sign Up

The sign-up input must be persisted in **sessionStorage** (not just component state) so it's
available on the verify-otp screen for resendOtp. Store it immediately before navigating.

```tsx
import { useSignUpMutation } from '@/state/auth/api'
import type { SignUpInput } from '@/types/auth.types'

const [signUp, { isLoading }] = useSignUpMutation()

// form state
const [firstName, setFirstName] = useState('')
const [lastName, setLastName]   = useState('')
const [email, setEmail]         = useState('')
const [password, setPassword]   = useState('')

const handleSignUp = async () => {
  const input: SignUpInput = {
    first_name: firstName,
    last_name: lastName,
    email,
    password,
    type: 'customer',
  }

  const result = await signUp(input)

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  // What happens internally (automatic — no action needed):
  // dispatch(setVerifyId(result.data.verify_id)) → state.auth.verifyId is set
  // verifyId is persisted via redux-persist (auth is whitelisted) — survives reload

  // Store the original sign-up input so the OTP screen can call resendOtp
  // without asking the user to re-enter their details
  sessionStorage.setItem('signup_input', JSON.stringify(input))

  // User is NOT authenticated yet — isAuthenticated is still false
  router.push('/verify-otp')
}
```

### Screen 2 — Verify OTP

Reads `verifyId` from Redux state. Guards against direct navigation (if verifyId is null,
the user hasn't signed up yet — redirect them back).

```tsx
import { useVerifyOtpMutation, useResendOtpMutation } from '@/state/auth/api'
import { useAuthSelector } from '@/state/auth/selectors'
import type { ResendOtpInput } from '@/types/auth.types'

const [verifyOtp, { isLoading: isVerifying }] = useVerifyOtpMutation()
const [resendOtp, { isLoading: isResending }] = useResendOtpMutation()
const verifyId = useAuthSelector(s => s.verifyId)

const [code, setCode] = useState('')

// Guard — if verifyId is null the user hasn't signed up or already verified
useEffect(() => {
  if (!verifyId) router.replace('/sign-up')
}, [verifyId])

// Submit OTP code
const handleVerify = async () => {
  if (!verifyId || !code) return

  const result = await verifyOtp({ verify_id: verifyId, code })

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  // What happens internally (automatic):
  // dispatch(setCredentials(user)) → isAuthenticated = true, authKey set, cookies written
  // state.auth.verifyId = null ← cleared
  // cartApi + listingApi caches invalidated → re-fetch with authenticated user's data

  sessionStorage.removeItem('signup_input')  // clean up
  router.push('/home')
}

// Resend OTP — requires the original sign-up input
const handleResend = async () => {
  // Retrieve the original input stored during sign-up
  const raw = sessionStorage.getItem('signup_input')
  if (!raw) {
    // Fallback: send user back to sign-up to start over
    router.replace('/sign-up')
    return
  }

  const input = JSON.parse(raw) as ResendOtpInput

  const result = await resendOtp(input)

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  // What happens internally:
  // dispatch(setVerifyId(result.data.verify_id)) → state.auth.verifyId updated with new code id
  // The verify-otp screen continues — no navigation needed
  showToast('New code sent')
}
```


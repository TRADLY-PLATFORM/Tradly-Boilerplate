## Reading Auth State

All fields are flat on `state.auth` — use `useAuthSelector` to read any of them.
Only read what the component actually needs.

```tsx
import { useAuthSelector } from '@/state/auth/selectors'

// Gate — most common
const isAuthenticated = useAuthSelector(s => s.isAuthenticated)

// Identity — profile screens, header avatar, greetings
const userId      = useAuthSelector(s => s.userId)       // "81ada464-c85c-..."
const firstName   = useAuthSelector(s => s.firstName)    // "Tradly"
const lastName    = useAuthSelector(s => s.lastName)     // "Team"
const profilePic  = useAuthSelector(s => s.profilePic)  // URL or empty string
const email       = useAuthSelector(s => s.email)        // "jk@istrata.co" or empty
const mobile      = useAuthSelector(s => s.mobile)       // "+60123456789" or empty
const dialCode    = useAuthSelector(s => s.dialCode)     // "+60" or empty

// Verification flags — 2FA flows, verified badge, settings screen
const emailVerified = useAuthSelector(s => s.emailVerified) // true / false
const otpEnabled    = useAuthSelector(s => s.otpEnabled)    // 2FA active?

// Tokens — rarely needed in components; API calls read authKey from state internally
const authKey   = useAuthSelector(s => s.authKey)
const verifyId  = useAuthSelector(s => s.verifyId)  // set after signUp, cleared after verifyOtp
```

### Common patterns

```tsx
// Show full name
const firstName = useAuthSelector(s => s.firstName)
const lastName  = useAuthSelector(s => s.lastName)
<span>{firstName} {lastName}</span>

// Conditional display — email vs phone account
const email    = useAuthSelector(s => s.email)
const mobile   = useAuthSelector(s => s.mobile)
const dialCode = useAuthSelector(s => s.dialCode)
<span>{email || `${dialCode} ${mobile}`}</span>

// Email verified badge
const emailVerified = useAuthSelector(s => s.emailVerified)
{!emailVerified && <span className="badge">Unverified</span>}

// 2FA / OTP settings toggle
const otpEnabled = useAuthSelector(s => s.otpEnabled)
<Toggle checked={otpEnabled} onChange={handleToggle2FA} />

// Auth gate in any component
const isAuthenticated = useAuthSelector(s => s.isAuthenticated)
if (!isAuthenticated) return router.push('/sign-in')
```


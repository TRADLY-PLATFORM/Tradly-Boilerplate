## Sign In

```tsx
import { useSignInMutation } from '@/state/auth/api'
import type { SignInInput } from '@/types/auth.types'

const [signIn, { isLoading }] = useSignInMutation()

const handleSignIn = async () => {
  const input: SignInInput = { email, password, type: 'customer' }
  // OR phone: { mobile, dial_code: '+1', password, type: 'customer' }

  const result = await signIn(input)

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  // State after success (setCredentials called internally):
  // state.auth.isAuthenticated = true
  // state.auth.userId          = user.id               (UUID string)
  // state.auth.firstName/lastName/email/mobile/dialCode populated
  // state.auth.profilePic      = user.profile_pic
  // state.auth.emailVerified   = user.email_verified
  // state.auth.otpEnabled      = user.otp_enabled
  // state.auth.authKey         = user.key.auth_key     ← used by all subsequent API calls
  // state.auth.refreshKey      = user.key.refresh_key
  // state.auth.tokenSetAt      = Date.now()
  // state.auth.verifyId        = null
  // Cookies: domain_auth_key, domain_refresh_key, domain_login, domain_logged_in_user_id set
  // Cart + Listing caches invalidated → re-fetch with authenticated user's data

  router.push('/home')
}
```


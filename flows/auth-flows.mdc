## Forgot Password — Step 1 (request OTP)

```tsx
import { useForgotPasswordMutation } from '@/state/auth/api'
import { useState } from 'react'

const [forgotPassword, { isLoading }] = useForgotPasswordMutation()
const [localVerifyId, setLocalVerifyId] = useState<string | null>(null)

const handleForgot = async () => {
  const result = await forgotPassword({ email })
  // OR phone: { mobile, dial_code: '+1' }

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  // NOTE: verify_id is NOT stored in Redux for forgot password (unlike sign-up)
  // Keep it in local component state to pass to step 2
  setLocalVerifyId(result.data.verify_id)
  router.push('/reset-password')
}
```

## Forgot Password — Step 2 (set new password)

```tsx
import { useSetPasswordMutation } from '@/state/auth/api'

const [setPassword, { isLoading }] = useSetPasswordMutation()

const handleSetPassword = async () => {
  const result = await setPassword({ verify_id: localVerifyId!, code, password })

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  // State: unchanged — user still not authenticated, must sign in
  router.push('/sign-in')
}
```


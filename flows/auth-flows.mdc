## Logout

```tsx
import { logout } from '@/state/auth/slice'
import { useDispatch } from 'react-redux'
import type { AppDispatch } from '@/state/store'

const dispatch = useDispatch<AppDispatch>()

const handleLogout = () => {
  dispatch(logout())
  // State after:
  // state.auth → reset to initialState (isAuthenticated: false, authKey: '', etc.)
  // All auth cookies deleted
  // cartApi cache reset → useGetCartQuery will re-fetch as guest on next call
  // listingApi cache reset → liked/in_cart fields re-fetch correctly

  router.push('/sign-in')
}
```


## Types Reference

```ts
// @/types/auth.types.ts

type AccountType = 'customer' | 'store'
type AuthProvider = 'google' | 'facebook' | 'apple'
type AuthPlatform = 'web' | 'ios' | 'android'

// What components pass in
interface SignInEmailInput  { email: string; password: string; type: AccountType }
interface SignInPhoneInput  { mobile: string; dial_code: string; password: string; type: AccountType }
type SignInInput = SignInEmailInput | SignInPhoneInput

interface SignUpEmailInput  { first_name: string; last_name: string; email: string; password: string; type: AccountType }
interface SignUpPhoneInput  { first_name: string; last_name: string; mobile: string; dial_code: string; password: string; type: AccountType }
type SignUpInput = SignUpEmailInput | SignUpPhoneInput

interface VerifyOtpInput    { verify_id: string; code: string }
interface ForgotPasswordInput { email?: string; mobile?: string; dial_code?: string }
interface SetPasswordInput  { verify_id: string; code: string; password: string }
type ResendOtpInput = SignUpEmailInput | SignUpPhoneInput
interface SocialSignInInput { provider: AuthProvider; token: string; platform: AuthPlatform; type: AccountType }

// What components receive from result.data
interface SignInResponse    { user: User }
interface SignUpResponse    { verify_id: string }
interface VerifyOtpResponse { user: User }
interface ForgotPasswordResponse { verify_id: string }
interface ResendOtpResponse { verify_id: string }
// setPassword → void

// Real API shape — matches actual Tradly sign-in / verify-OTP response
interface UserMetadata {
  stripe_connected: boolean
  stripe_connect_onboarding: boolean
  mangopay_kyc_submission: boolean
  mangopay_payouts_enabled: boolean
}

interface User {
  id: string                  // UUID string e.g. "81ada464-c85c-..."
  first_name: string
  last_name: string
  email: string               // always present, may be empty string
  mobile: string              // always present, may be empty string
  dial_code: string           // always present, may be empty string
  profile_pic?: string
  birth_date: string | null
  email_verified: boolean
  otp_enabled: boolean
  metadata: UserMetadata      // payment provider flags
  key: {
    auth_key: string
    refresh_key: string
    firebase_token?: string   // absent when not using Firebase
  }
}
```


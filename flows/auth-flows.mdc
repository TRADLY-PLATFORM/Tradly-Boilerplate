## Social Sign In

```tsx
import { useSocialSignInMutation } from '@/state/auth/api'
import type { SocialSignInInput } from '@/types/auth.types'

const [socialSignIn, { isLoading }] = useSocialSignInMutation()

const handleGoogleSignIn = async (googleToken: string) => {
  const input: SocialSignInInput = {
    provider: 'google',
    token: googleToken,
    platform: 'web',
    type: 'customer',
  }

  const result = await socialSignIn(input)

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
    return
  }

  // State: same as sign in
  router.push('/home')
}
```


## Category Listings Page — Full Pattern

Combines `useGetCategoryBySlugQuery` + `useGetCategoryListingsQuery` on a single page.

```tsx
import { useGetCategoryBySlugQuery, useGetCategoryListingsQuery } from '@/state/categories/api'
import { useLikeListingMutation, useUnlikeListingMutation } from '@/state/listing/api'

function CategoryListingsPage() {
  const router = useRouter()
  const slug   = router.query.slug as string
  const [page, setPage] = useState(1)

  // 1. Resolve category detail from slug
  const { data: catData, isLoading: catLoading, isError: catError } =
    useGetCategoryBySlugQuery(slug, { skip: !slug })

  const category = catData?.category

  // 2. Fetch listings once category id is known
  const { data: listData, isLoading: listLoading, isFetching } =
    useGetCategoryListingsQuery(
      { category_id: category!.id, page },
      { skip: !category?.id },
    )

  // 3. Redirect to 404 if category not found
  useEffect(() => {
    if (!catLoading && catError) router.replace('/not-found')
  }, [catLoading, catError])

  // 4. Reset to page 1 when slug changes (user navigated to different category)
  useEffect(() => { setPage(1) }, [slug])

  const listings     = listData?.listings ?? []
  const totalPages   = Math.ceil((listData?.total_records ?? 0) / 30)
  const currentPage  = listData?.page ?? 1

  if (catLoading) return <PageSkeleton />

  return (
    <div>
      {/* Breadcrumb — using hierarchy */}
      <Breadcrumb
        items={[
          { name: 'Home', href: '/' },
          { name: 'Categories', href: '/lc' },
          ...(category?.hierarchy?.map(h => ({
            name: h.name,
            href: `/lc/${h.slug ?? `${h.id}-${toSlug(String(h.name))}`}`,
          })) ?? []),
          { name: category?.name ?? '', href: '' },
        ]}
      />

      {/* Category header */}
      {category?.image && <img src={category.image} alt={category.name} />}
      <h1>{category?.name}</h1>
      {category?.description && <p>{category.description}</p>}

      {/* Subcategory chips — quick filter into child category */}
      {(category?.sub_category?.length ?? 0) > 0 && (
        <div className="flex gap-2">
          {category!.sub_category!.map(sub => (
            <Link key={sub.id} href={`/lc/${getCategorySlug(sub)}`}>
              {sub.name}
            </Link>
          ))}
        </div>
      )}

      {/* Listings grid */}
      {listLoading ? (
        <ListingsSkeleton />
      ) : listings.length === 0 ? (
        <EmptyState message="No listings in this category yet." />
      ) : (
        <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-4">
          {listings.map(listing => (
            <ListingCard key={listing.id} listing={listing} />
          ))}
        </div>
      )}

      {/* Pagination */}
      {totalPages > 1 && (
        <ReactPaginate
          pageCount={totalPages}
          forcePage={currentPage - 1}
          onPageChange={({ selected }) => setPage(selected + 1)}
        />
      )}
    </div>
  )
}
```


## Fetch Listing Categories (type: 'listing')

```tsx
import { useGetCategoriesQuery } from '@/state/categories/api'

// Omit type for listing categories (it's the default)
const { data, isLoading } = useGetCategoriesQuery({ page: 1 })

const categories = data?.categories ?? []

// Root-level categories (no parent)
const rootCategories = categories.filter(c => !c.parent_id)

// Subcategories of a given root (via sub_category on the parent object)
// The SDK returns nested sub_category arrays directly — no separate fetch needed
rootCategories[0]?.sub_category  // Category[] — children of first root category

// Category card / menu item
categories.map(category => ({
  id:          category.id,
  name:        category.name,
  image:       category.image,
  href:        `/lc/${getCategorySlug(category)}`,
  hasChildren: (category.sub_category?.length ?? 0) > 0,
}))
```


## Category Dropdown / Navigation Menu

Render the category tree in a header nav or sidebar. Use `sub_category` for nested rendering.

```tsx
import { useGetCategoriesQuery } from '@/state/categories/api'

function CategoryNav() {
  const { data } = useGetCategoriesQuery({ page: 1 })
  const categories = data?.categories ?? []

  return (
    <nav>
      {categories.map(category => (
        <CategoryMenuItem key={category.id} category={category} />
      ))}
    </nav>
  )
}

// Recursive — renders children when sub_category is non-empty
function CategoryMenuItem({ category }: { category: Category }) {
  const hasChildren = (category.sub_category?.length ?? 0) > 0
  const slug = getCategorySlug(category)

  if (!hasChildren) {
    return (
      <Link href={`/lc/${slug}`}>{category.name}</Link>
    )
  }

  return (
    <div className="group relative">
      <Link href={`/lc/${slug}`}>{category.name}</Link>

      {/* Dropdown — visible on hover via group-hover */}
      <div className="hidden group-hover:block absolute top-full left-0 z-10 bg-white shadow-lg">
        {category.sub_category!.map(child => (
          <CategoryMenuItem key={child.id} category={child} />
        ))}
      </div>
    </div>
  )
}
```

### Active state — highlight current category in nav

```tsx
const slug = router.query.slug as string

const isActive = (category: Category): boolean =>
  slug === getCategorySlug(category) ||
  // Also active when viewing a child — check hierarchy
  (category.sub_category?.some(child => getCategorySlug(child) === slug) ?? false)

<Link
  href={`/lc/${getCategorySlug(category)}`}
  className={isActive(category) ? 'text-primary font-bold' : ''}
>
  {category.name}
</Link>
```


## Types Reference

```ts
// @/types/category.types.ts

interface CategoryHierarchy {
  id: string | number
  name: string
  slug?: string
}

interface Category {
  id: string | number
  name: string
  slug?: string
  description?: string
  image?: string
  parent_id?: string | number | null
  sub_category?: Category[]       // nested children — may be empty []
  hierarchy?: CategoryHierarchy[] // ancestors from root to current — for breadcrumbs
  type?: 'listing' | 'account'
}

interface GetCategoriesParams {
  page?: number
  type?: 'listing' | 'account'  // omit for listing categories (default)
}

interface GetCategoryListingsParams {
  category_id: number | string   // required
  page?: number
  limit?: number
  [key: string]: unknown         // any additional listing filters (price, sort, etc.)
}
```


## Category on Listing Detail Page

Display the category breadcrumb/hierarchy from a listing's `categories` field — no extra fetch needed.

```tsx
// listing.categories comes from useGetListingDetailQuery — already in cache
// Each category has a `hierarchy` array from root → current

import { slug as toSlug } from 'github-slugger'

function ListingCategoryBreadcrumb({ listing }: { listing: Listing }) {
  const firstCategory = listing.categories[0]
  if (!firstCategory?.hierarchy?.length) return null

  return (
    <div className="flex items-center gap-1 text-sm text-gray-500">
      {firstCategory.hierarchy.map((item, index, arr) => (
        <span key={item.id} className="flex items-center gap-1">
          <Link href={`/lc/${item.slug ?? `${item.id}-${toSlug(String(item.name))}`}`}>
            {item.name}
          </Link>
          {index < arr.length - 1 && <span>›</span>}
        </span>
      ))}
    </div>
  )
}
```


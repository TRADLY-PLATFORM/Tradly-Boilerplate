## What NOT to do

```ts
// Never fetch category listings without category_id — the param is required
useGetCategoryListingsQuery({ page: 1 })  // ❌ category_id missing
useGetCategoryListingsQuery({ category_id: categoryId, page: 1 }, { skip: !categoryId })  // ✓

// Never hardcode slug construction as id + name without toSlug — spaces will break URLs
const slug = `${category.id}-${category.name}`          // ❌ "123-My Category"
const slug = `${category.id}-${toSlug(category.name)}`  // ✓ "123-my-category"

// Never implement your own slug→ID fallback — it's already in state/categories/api.ts
// useGetCategoryBySlugQuery handles the fallback internally

// Never fetch category detail and category listings with two separate useEffect chains
// Use skip: !category?.id to chain them declaratively

// Never use all_categories from old Redux slice — use useGetCategoriesQuery instead

// Never show sub_category children without checking length > 0 first
category.sub_category.map(...)           // ❌ may be undefined or []
(category.sub_category?.length ?? 0) > 0 // ✓ guard first

// Never link to /lc/[id] directly — always go through slug generation
href={`/lc/${category.id}`}              // ❌ — ID alone may not resolve
href={`/lc/${getCategorySlug(category)}`} // ✓
```

## Fetch Listings in a Category

Category listings page: show all listings that belong to the selected category.

```tsx
import { useGetCategoryListingsQuery } from '@/state/categories/api'
import type { GetCategoryListingsParams } from '@/types/category.types'

const [page, setPage] = useState(1)
const categoryId = data?.category?.id  // from useGetCategoryBySlugQuery above

const { data: listingsData, isLoading, isFetching } = useGetCategoryListingsQuery(
  { category_id: categoryId!, page, limit: 30 },
  { skip: !categoryId },
)

const listings      = listingsData?.listings ?? []
const totalRecords  = listingsData?.total_records ?? 0
const totalPages    = Math.ceil(totalRecords / 30)
const currentPage   = listingsData?.page ?? 1

// Pagination
<ReactPaginate
  pageCount={totalPages}
  forcePage={currentPage - 1}
  onPageChange={({ selected }) => setPage(selected + 1)}
/>

// Empty state
{!isLoading && listings.length === 0 && (
  <p>No listings found in this category.</p>
)}
```

### With extra filters

Pass any listing filter param alongside `category_id` — they all go into the same `bodyParam`.

```tsx
const params: GetCategoryListingsParams = {
  category_id: categoryId!,
  page,
  limit: 30,
  // Optional filters — append as needed from URL query or filter UI
  ...(router.query.min_price  ? { min_price:  Number(router.query.min_price)  } : {}),
  ...(router.query.max_price  ? { max_price:  Number(router.query.max_price)  } : {}),
  ...(router.query.sort_by    ? { sort_by:    router.query.sort_by            } : {}),
  ...(router.query.order_type ? { type:       router.query.order_type         } : {}),
}

const { data } = useGetCategoryListingsQuery(params, { skip: !categoryId })
```


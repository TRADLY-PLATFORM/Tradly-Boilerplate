## Slug Generation

Categories use URL slugs for routing. When a category has no slug, generate one from its ID and name.

```tsx
import { slug as toSlug } from 'github-slugger'

// Pattern: use slug if available, fallback to "id-name"
const getCategorySlug = (category: Category): string =>
  category.slug ?? `${category.id}-${toSlug(String(category.name))}`

// Examples:
// { id: 123, name: "Electronics", slug: "electronics" } → "electronics"
// { id: 123, name: "Electronics", slug: undefined }     → "123-electronics"
// { id: 123, name: "Café & Restaurant" }                → "123-caf-restaurant"

// Route path
const href = { pathname: '/lc/[slug]', query: { slug: getCategorySlug(category) } }
```


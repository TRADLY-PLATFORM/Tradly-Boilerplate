## Like / Unlike

Both mutations invalidate the listing cache — list and detail re-fetch with updated `liked`.
Like/unlike is available on all order types.

```tsx
import { useLikeListingMutation, useUnlikeListingMutation } from '@/state/listing/api'
import { useAuthSelector } from '@/state/auth/selectors'
import type { Listing } from '@/types/listing.types'

const [likeListing, { isLoading: isLiking }] = useLikeListingMutation()
const [unlikeListing, { isLoading: isUnliking }] = useUnlikeListingMutation()
const isAuthenticated = useAuthSelector(s => s.isAuthenticated)

const handleToggleLike = async (listing: Listing) => {
  if (!isAuthenticated) { router.push('/sign-in'); return }

  const result = listing.liked
    ? await unlikeListing({ id: listing.id })
    : await likeListing({ id: listing.id })

  if ('error' in result) {
    showToast((result.error as { error: string }).error)
  }
  // listing.liked updates automatically via cache invalidation — no setState needed
}

<button onClick={() => handleToggleLike(listing)} disabled={isLiking || isUnliking}>
  {listing.liked ? '♥' : '♡'} {listing.likes}
</button>
```


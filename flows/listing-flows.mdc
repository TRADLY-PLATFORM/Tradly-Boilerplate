## What NOT to do

```ts
// Never branch on type as number — it's a string
if (listing.type === 2) // ❌
if (listing.order_type === 'events') // ✓

// Never use "price" — the real field is "list_price"
listing.price.formatted        // ❌ undefined
listing.list_price.formatted   // ✓

// Never use "is_liked" — the real field is "liked"
listing.is_liked  // ❌
listing.liked     // ✓

// Never use "rating_average" directly
listing.rating_average               // ❌
listing.rating_data.rating_average   // ✓

// Never use "account.profile_pic"
listing.account.profile_pic  // ❌
listing.account.images[0]    // ✓

// Never show Add to Cart for information_listing, video_listing, or requests

// Never skip clearCart for events / appointments / donations

// Never manually update liked or in_cart — cache invalidation handles it
setIsInCart(true)  // ❌
```

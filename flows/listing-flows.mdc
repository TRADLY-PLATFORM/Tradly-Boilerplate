## Listings List

```tsx
import { useGetListingsQuery } from '@/state/listing/api'
import type { GetListingsParams } from '@/types/listing.types'

const { data, isLoading, isError } = useGetListingsQuery({ page: 1, limit: 20 })

// data.listings      → Listing[]
// data.page          → number
// data.total_records → number

if (isLoading) return <Spinner />
return data?.listings.map(listing => <ListingCard key={listing.id} listing={listing} />)
```

### Listing card — key fields

```tsx
listing.images[0]                          // hero image
listing.title
listing.order_type                         // use to show correct badge or CTA hint
listing.list_price.formatted               // "$ 23.00" — strikethrough (original)
listing.offer_price.formatted              // "$ 22.54" — main price
listing.offer_percent                      // 2 — "2% OFF" badge, hide when 0
listing.stock                              // 0 = show "Out of stock" badge
listing.sold                               // true = permanently sold
listing.liked                              // heart icon state
listing.in_cart                            // cart icon indicator
listing.account.name                       // "Super Shop"
listing.account.images[0]                 // seller avatar
listing.account.following                  // follow button state
listing.rating_data.rating_average        // 4.5
listing.rating_data.review_count          // 42
listing.categories[0]?.hierarchy          // breadcrumb data
// For events/appointments — show date badge
listing.start_at                           // unix timestamp → format as date
```

### Pagination

```tsx
const [page, setPage] = useState(1)
const { data } = useGetListingsQuery({ page, limit: 20 })
const totalPages = Math.ceil((data?.total_records ?? 0) / 20)
```

### Filter by order_type

```tsx
// Physical products only
useGetListingsQuery({ page: 1, type: 'listings' })

// Events only
useGetListingsQuery({ page: 1, type: 'events' })


## Listing Detail

```tsx
import { useGetListingDetailQuery } from '@/state/listing/api'

// By slug (most common)
const { data, isLoading } = useGetListingDetailQuery({ slug: 'my-product' })

// By numeric ID (when slug starts with digits e.g. "727753-dsf")
const { data } = useGetListingDetailQuery({ slug: '727753-dsf', id: true })

// From router — skip until slug is available
const { data, isLoading } = useGetListingDetailQuery(
  { slug: router.query.slug as string, id: router.query.id as string },
  { skip: !router.query.slug }
)

const listing = data?.listing
```

### Detail page — full field reference

```tsx
// Core identity
listing.title
listing.description          // may contain HTML → dangerouslySetInnerHTML
listing.order_type           // ← branch all CTA logic on this

// Pricing
listing.list_price.formatted          // original price (strikethrough)
listing.offer_price.formatted         // discounted price (main)
listing.offer_percent                 // hide when 0
listing.shipping_charges.formatted    // "$ 0.00" = free shipping
listing.goal_price.formatted          // donation goal (donation type only)

// Inventory
listing.stock                         // 0 = disable add-to-cart
listing.max_quantity                  // cap quantity picker
listing.sold                          // permanently sold — show sold banner

// Media
listing.images                        // string[] — image gallery
listing.videos                        // string[] — video player

// Engagement
listing.liked                         // heart button state
listing.likes                         // like count display
listing.in_cart                       // cart button state

// Dates — relevant for events/appointments
listing.start_at                      // event start (unix ts) → format & display
listing.end_at                        // event end
listing.schedules                     // [] for products, time slots for events

// Seller
listing.account.name
listing.account.slug                  // → link to store page
listing.account.images[0]            // seller avatar/banner
listing.account.description
listing.account.total_followers
listing.account.total_listings
listing.account.following             // follow/unfollow button state
listing.account.rating_data.rating_average
listing.account.location.formatted_address
listing.account.shipping_methods      // ShippingMethod[] — show delivery options

// Categories — breadcrumb
listing.categories[0]?.hierarchy.map(h => h.name).join(' > ')  // "Men > Hoodies"

// Rating
listing.rating_data.rating_average
listing.rating_data.review_count
listing.rating_data.rating_count_data // { rating_1..5 } for breakdown bar

// Attributes — show only visible ones
const visibleAttrs = listing.attributes.filter(a => a.visible)

// Variants — show selector when length > 0
listing.variants.length > 0  // → render variant picker
```


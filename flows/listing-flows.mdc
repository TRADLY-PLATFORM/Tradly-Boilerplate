## Detail CTA — Branch by order_type

The action area of the detail page should branch entirely on `listing.order_type`.

```tsx
import type { Listing } from '@/types/listing.types'

function ListingDetailCTA({ listing }: { listing: Listing }) {
  const { order_type } = listing

  // Physical & digital — standard cart flow
  if (order_type === 'listings' || order_type === 'digital') {
    return <ProductCTA listing={listing} />
  }

  // Events & appointments — auth + clear cart + book
  if (order_type === 'events' || order_type === 'appointments') {
    return <EventCTA listing={listing} />
  }

  // Donation — custom price + clear cart
  if (order_type === 'donation') {
    return <DonationCTA listing={listing} />
  }

  // Information — no cart, enquiry only
  if (order_type === 'information_listing') {
    return <EnquiryCTA listing={listing} />
  }

  // Video — content access
  if (order_type === 'video_listing') {
    return <VideoCTA listing={listing} />
  }

  // Reverse marketplace — post a request
  if (order_type === 'requests') {
    return <RequestCTA listing={listing} />
  }

  return null
}
```

### listings / digital — ProductCTA

```tsx
// Show: quantity picker, variant selector, Add to Cart, Buy Now
// No auth gate — guests can add to cart (uuid injected automatically)
// digital: hide shipping_methods and shipping_charges display

function ProductCTA({ listing }: { listing: Listing }) {
  const isDigital = listing.order_type === 'digital'

  return (
    <div>
      {!isDigital && <ShippingDisplay methods={listing.account.shipping_methods} />}
      {(listing.variants as unknown[]).length > 0 && <VariantPicker variants={listing.variants} />}
      <QuantityPicker max={listing.max_quantity} stock={listing.stock} />
      <AddToCartButton listing={listing} />
      <BuyNowButton listing={listing} />
    </div>
  )
}
```

### events / appointments — EventCTA

```tsx
// Show: schedule/slot picker, Book Now (single button)
// Auth required before booking
// Always clears cart before adding — see cart-flows.mdc → events/appointments section

function EventCTA({ listing }: { listing: Listing }) {
  const isAppointment = listing.order_type === 'appointments'

  return (
    <div>
      <DateDisplay startAt={listing.start_at} endAt={listing.end_at} />
      {(listing.schedules as unknown[]).length > 0 && (
        <SchedulePicker schedules={listing.schedules} />
      )}
      {(listing.variants as unknown[]).length > 0 && (
        <VariantPicker variants={listing.variants} label={isAppointment ? 'Select slot' : 'Select ticket'} />
      )}
      <BookNowButton listing={listing} label={isAppointment ? 'Book Appointment' : 'Book Now'} />
    </div>
  )
}
```

### donation — DonationCTA

```tsx
// Show: goal progress bar, custom amount input, Fund Now
// No auth gate — guests can donate
// Clears cart before adding — see cart-flows.mdc → donation section

function DonationCTA({ listing }: { listing: Listing }) {
  const [amount, setAmount] = useState<number>(0)
  const goalAmount = listing.goal_price.amount

  return (
    <div>
      {goalAmount > 0 && (
        <GoalProgressBar
          goal={listing.goal_price.formatted}
          progressPercent={Math.min((raisedAmount / goalAmount) * 100, 100)}
        />
      )}
      <input
        type="number"
        placeholder="Enter amount"
        value={amount}
        onChange={e => setAmount(Number(e.target.value))}
      />
      <FundNowButton listing={listing} donationAmount={amount} />
    </div>
  )
}
```

### information_listing — EnquiryCTA

```tsx
// No cart — this is a lead capture or information page
// Show: seller contact info, enquiry form link

function EnquiryCTA({ listing }: { listing: Listing }) {
  return (
    <div>
      <p>{listing.account.name}</p>
      <p>{listing.account.location.formatted_address}</p>
      <button onClick={() => router.push(`/contact?listing=${listing.id}`)}>
        Enquire Now
      </button>
    </div>
  )
}
```

### video_listing — VideoCTA

```tsx
// No cart — content access
// listing.videos[0] is the video URL/embed

function VideoCTA({ listing }: { listing: Listing }) {
  return (
    <div>
      {(listing.videos as string[]).length > 0 && (
        <VideoPlayer url={(listing.videos as string[])[0]} />
      )}
      <button onClick={() => router.push(`/watch/${listing.slug}`)}>
        Watch Now
      </button>
    </div>
  )
}
```

### requests — RequestCTA

```tsx
// Reverse marketplace — buyer posts a need, sellers respond
// Auth required — guests cannot post requests

function RequestCTA({ listing }: { listing: Listing }) {
  const isAuthenticated = useAuthSelector(s => s.isAuthenticated)

  const handleSubmitRequest = () => {
    if (!isAuthenticated) { router.push('/sign-in'); return }
    router.push(`/requests/new?category=${listing.category_id[0]}&ref=${listing.id}`)
  }

  return (
    <div>
      <p>Looking for something like this? Post a request and sellers will reach out.</p>
      <button onClick={handleSubmitRequest}>Post a Request</button>
    </div>
  )
}
```


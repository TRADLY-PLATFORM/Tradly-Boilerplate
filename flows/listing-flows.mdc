## Types Reference

```ts
// @/types/listing.types.ts

interface Money {
  amount: number; currency: string
  formatted: string    // e.g. "$ 23.00" ← always use this for display
}

interface CategoryHierarchy {
  id: number; name: string; level: number; slug: string
}

interface Category {
  id: number; name: string; slug: string
  parent: number       // 0 if root category
  active: boolean; image_path: string
  hierarchy: CategoryHierarchy[]
  sub_category: Category[]
}

interface RatingData {
  rating_average: number    // ← "rating_average" not "average_rating"
  rating_count: number; review_count: number
  rating_count_data: { rating_1: number; rating_2: number; rating_3: number; rating_4: number; rating_5: number }
}

interface ShippingMethod {
  id: number; name: string
  type: string    // "pickup" | "delivery" | "storage_hub"
  active: boolean; default: boolean; order_by: number
}

interface ListingAccount {
  id: number; name: string; slug: string; description: string
  images: string[]         // ← images[] not profile_pic
  following: boolean
  total_followers: number; total_listings: number
  location: AccountLocation
  shipping_methods: ShippingMethod[]
  rating_data: AccountRatingData
  categories: Category[]
}

interface Listing {
  id: number; slug: string; title: string
  description: string      // may contain HTML
  order_type: string       // "listings" | "events" | "appointments" | "donation" |
                           // "digital" | "information_listing" | "video_listing" | "requests"
  type: string             // same value as order_type — use order_type for branching

  // Pricing
  list_price: Money        // ← "list_price" not "price" — show as strikethrough
  offer_price: Money       // main display price
  goal_price: Money        // fundraising target (donation type)
  offer_percent: number    // e.g. 2 (%)
  shipping_charges: Money

  // Inventory
  stock: number
  max_quantity: number     // cap quantity picker at this value
  sold: boolean; active: boolean

  // Media
  images: string[]; videos: string[]

  // Engagement (update via cache — never setState)
  liked: boolean           // ← "liked" not "is_liked"
  unliked: boolean; likes: number; unlikes: number
  in_cart: boolean

  // Dates (unix timestamps — relevant for events/appointments)
  start_at: number; end_at: number; created_at: number

  // Relationships
  account_id: number; account: ListingAccount
  categories: Category[]

  // Extended
  rating_data: RatingData
  attributes: ListingAttribute[]
  variants: unknown[]      // show variant selector when length > 0
  schedules: unknown[]     // event time slots / appointment availability
}
```

